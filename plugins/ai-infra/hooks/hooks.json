{
  "PreToolUse": [
    {
      "_oma": "oma-harness-enforce",
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/enforce.py\""
        }
      ]
    }
  ],
  "SessionStart": [
    {
      "_oma": "oma-session-start",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start-ontology.sh\""
        }
      ]
    }
  ]
}
